# Fill in from `cd terraform && terraform output access_key_id` and
# `terraform output -raw secret_access_key`. The playbook won't clobber this
# file once it exists (force: false on the template task).

# Underlying S3 remote — used by crypt: as its backend.
RCLONE_CONFIG_S3_TYPE=s3
RCLONE_CONFIG_S3_PROVIDER=AWS
RCLONE_CONFIG_S3_REGION=us-east-1
RCLONE_CONFIG_S3_ACCESS_KEY_ID=CHANGE_ME
RCLONE_CONFIG_S3_SECRET_ACCESS_KEY=CHANGE_ME
# Default class for uploaded current versions. Reachable instantly; superseded
# versions get pushed to Deep Archive by the bucket lifecycle rule.
RCLONE_CONFIG_S3_STORAGE_CLASS=GLACIER_IR

# Client-side encrypted overlay. Filenames + directories pass through plaintext
# (browsable in the AWS console); file contents are AES-encrypted before
# upload.  LOSE THE PASSPHRASE = LOSE THE DATA. Store both PASSWORD and
# PASSWORD2 in 1Password. Generate the obscured forms with:
#   rclone obscure 'your-strong-passphrase'
#   rclone obscure 'your-strong-salt'
RCLONE_CONFIG_CRYPT_TYPE=crypt
RCLONE_CONFIG_CRYPT_REMOTE=s3:CHANGE_ME-bucket-name
RCLONE_CONFIG_CRYPT_FILENAME_ENCRYPTION=off
RCLONE_CONFIG_CRYPT_DIRECTORY_NAME_ENCRYPTION=false
RCLONE_CONFIG_CRYPT_PASSWORD=CHANGE_ME
RCLONE_CONFIG_CRYPT_PASSWORD2=CHANGE_ME
