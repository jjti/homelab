# Shared by immich-server + immich-postgres. Both names cover both consumers
# (Postgres uses POSTGRES_*, Immich uses DB_*). Keep the two passwords in sync.
# Generate a strong value once, then never rotate without also resetting the DB.

POSTGRES_USER=immich
POSTGRES_DB=immich
POSTGRES_PASSWORD=CHANGE_ME

DB_USERNAME=immich
DB_DATABASE_NAME=immich
DB_PASSWORD=CHANGE_ME
