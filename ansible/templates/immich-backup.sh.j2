#!/usr/bin/env bash
# Nightly Immich backup:
#  - pg_dump of the immich database (custom format, supports parallel restore)
#  - rclone sync of /mnt/photos/immich/library (originals only — thumbs +
#    encoded-video are regenerated by Immich on demand).
# Uploads through rclone's `crypt:` remote, so contents are AES-encrypted
# client-side before they hit S3. Filenames stay plaintext (see env file).
# Bucket versioning + lifecycle (see terraform/main.tf) keeps superseded
# versions for ~7d in the current class, then Deep Archive, expiring at 365d.
set -euo pipefail

PHOTOS_SRC="/mnt/photos/immich"
DUMP_DIR="${HOME}/.cache/immich-backup"
DUMP_FILE="${DUMP_DIR}/immich-db.dump"

mkdir -p "${DUMP_DIR}"

ts() { date -Iseconds; }

echo "[$(ts)] dumping postgres"
# Write to a .tmp first; mv is atomic. Avoids leaving a half-written dump if
# the container dies mid-stream.
podman exec immich-postgres pg_dump -U immich -d immich -F c > "${DUMP_FILE}.tmp"
mv "${DUMP_FILE}.tmp" "${DUMP_FILE}"

echo "[$(ts)] syncing originals -> crypt:photos/ (encrypted)"
# Back up upload/ (where Immich stores originals by default) + library/ (where
# Storage Template Migration moves them, if enabled) + profile/ (avatars).
# Skip the derivatives Immich regenerates from originals + its own internal
# pg dumps (we capture postgres separately via pg_dump below).
rclone sync "${PHOTOS_SRC}" crypt:photos/ \
    --exclude '/thumbs/**' \
    --exclude '/encoded-video/**' \
    --exclude '/backups/**' \
    --transfers=4 --checkers=8 --fast-list --s3-no-check-bucket --stats=1m

echo "[$(ts)] uploading db dump -> crypt:db/ (encrypted)"
rclone copy "${DUMP_FILE}" crypt:db/ \
    --s3-no-check-bucket

echo "[$(ts)] backup complete"
