# Laravel app key — auto-generated by the container on first start if blank.
# Once generated it will be written into /config/.env; leave this blank.
APP_KEY=
# Cron schedule for automatic speed tests (default: every 3 hours).
SPEEDTEST_SCHEDULE=0 0,2,4,7,19,22 * * *
# Optional: lock to specific Ookla server IDs (comma-separated).
# Find IDs at https://www.speedtest.net/speedtest-servers.php
# Leave blank to auto-select nearest server.
#SPEEDTEST_SERVER_IDS=
